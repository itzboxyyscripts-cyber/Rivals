getKeyBtn.MouseButton1Click:Connect(function()
    if syn and syn.open_url then
        syn.open_url(DISCORD_LINK)
    elseif shellexecute then
        shellexecute(DISCORD_LINK)
    elseif os and os.execute then
        os.execute('start "" "' .. DISCORD_LINK .. '"')
    else
        pcall(function()
            game:GetService("GuiService"):OpenBrowserWindow(DISCORD_LINK)
        end)
        pcall(function()
            setclipboard(DISCORD_LINK)
        end)
        statusLabel.Text = "Link copied! Paste in browser."
        statusLabel.TextColor3 = Color3.fromRGB(88, 101, 242)
    end
end)

submitBtn.MouseButton1Click:Connect(function()
    if inputBox.Text == VALID_KEY then
        keyGui:Destroy()
        loadstring(game:HttpGet("https://pastefy.app/YiGY38uo/raw"))()
    else
        statusLabel.Text = "❌ Invalid key. Click 'Get Key' to get yours."
        inputBox.Text = ""
    end
end)
